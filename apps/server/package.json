{
  "name": "zzyix-server",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "nodemon --exec node --loader ts-node/esm src/index.ts",
    "build": "tsc",
    "lint": "oxlint",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:rollback": "echo 'Rollback uses authored reverse SQL migrations; no automatic rollback command is configured.'",
    "test": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@socket.io/postgres-adapter": "^0.4.0",
    "drizzle-orm": "^0.44.5",
    "express": "^4.20.1",
    "node-cron": "^4.2.1",
    "pg": "^8.16.3",
    "socket.io": "^4.8.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.23",
    "@types/node": "^24.13.2",
    "@types/pg": "^8.15.5",
    "@vitest/coverage-v8": "^4.1.10",
    "drizzle-kit": "^0.31.4",
    "nodemon": "^3.1.7",
    "oxlint": "^1.71.0",
    "pg-mem": "^3.0.5",
    "testcontainers": "^11.7.1",
    "ts-node": "^10.9.2",
    "typescript": "~6.0.2",
    "vitest": "^4.1.10"
  }
}
