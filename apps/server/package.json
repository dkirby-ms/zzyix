{
  "name": "zzyix-server",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "nodemon --exec 'node --env-file=../../.env --import tsx/esm' src/index.ts",
    "build": "tsc",
    "lint": "oxlint",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:rollback": "echo 'Rollback uses authored reverse SQL migrations; no automatic rollback command is configured.'",
    "test": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@socket.io/postgres-adapter": "^0.5.0",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "node-cron": "^4.2.1",
    "pg": "^8.16.3",
    "socket.io": "^4.8.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.15.5",
    "@vitest/coverage-v8": "^4.1.10",
    "drizzle-kit": "^1.0.0-beta.22",
    "nodemon": "^3.1.7",
    "oxlint": "^1.71.0",
    "pg-mem": "^3.0.5",
    "testcontainers": "^12.0.4",
    "tsx": "^4.23.1",
    "typescript": "~7.0.2",
    "vitest": "^4.1.10"
  }
}
